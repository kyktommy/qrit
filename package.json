{
  "name": "qrit",
  "version": "0.2.0",
  "description": "Turn a QR code into a two-way LAN file drop. Scan, download, upload.",
  "type": "module",
  "bin": {
    "qrit": "./dist/qrit.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --target=bun --outfile=dist/qrit.js --minify",
    "compile": "bash scripts/compile.sh",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "keywords": [
    "qr",
    "qrcode",
    "cli",
    "lan",
    "share",
    "airdrop",
    "ink",
    "bun"
  ],
  "author": "kyktommy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyktommy/qrit.git"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
